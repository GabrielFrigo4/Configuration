{
	// ==========================================
	// INTERFACE
	// ==========================================
	"base_keymap": "VSCode",
	"theme": {
		"mode": "system",
		"light": "One Light",
		"dark": "One Dark",
	},
	"outline_panel": {
		"dock": "left",
	},
	"collaboration_panel": {
		"dock": "left",
	},
	"project_panel": {
		"dock": "left",
	},
	"git_panel": {
		"dock": "left",
	},

	// ==========================================
	// APARÊNCIA
	// ==========================================
	"ui_font_family": "JetBrainsMono Nerd Font Mono",
	"buffer_font_family": "JetBrainsMono Nerd Font Mono",
	"ui_font_size": 16,
	"buffer_font_size": 16,
	"scrollbar": {
		"show": "always",
	},

	// ==========================================
	// CORE
	// ==========================================
	"vim_mode": false,
	"show_edit_predictions": false,
	"hard_tabs": false,
	"tab_size": 4,

	// ==========================================
	// TELEMETRIA
	// ==========================================
	"telemetry": {
		"metrics": false,
	},

	// ==========================================
	// TERMINAL
	// ==========================================
	"terminal": {
		"font_family": "JetBrainsMono Nerd Font Mono",
		"line_height": "standard",
		"blinking": "terminal_controlled",
	},

	// ==========================================
	// LINGUAGENS
	// ==========================================
	"languages": {
		"Go": {
			"hard_tabs": true,
			"tab_size": 4,
		},
		"Make": {
			"hard_tabs": true,
			"tab_size": 4,
		},
	},

	// ==========================================
	// LSP
	// ==========================================
	"lsp": {
		"clangd": {
			"binary": {
				"path": "clangd",
				"arguments": [
					"--background-index",
					"--compile-commands-dir=build",
					"--clang-tidy",
					"--header-insertion=never",
				],
			},
		},
		"rust-analyzer": {
			"initialization_options": {
				"checkOnSave": {
					"command": "check",
				},
			},
		},
	},

	// ==========================================
	// IA
	// ==========================================
	"agent": {
		"dock": "right",
		"favorite_models": [],
		"model_parameters": [],
	},
}
